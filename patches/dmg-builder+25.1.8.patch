diff --git a/node_modules/dmg-builder/out/dmg.js b/node_modules/dmg-builder/out/dmg.js
index 94af8a1..e2047a2 100644
--- a/node_modules/dmg-builder/out/dmg.js
+++ b/node_modules/dmg-builder/out/dmg.js
@@ -173,12 +173,16 @@ async function createStageDmg(tempDmg, appPath, volumeName) {
     if (builder_util_1.log.isDebugEnabled) {
         imageArgs.push("-debug");
     }
+    // CLACOROO patch (patch-package): forziamo SEMPRE HFS+ anche su arm64.
+    // Il blocco originale forzava APFS su arm64 (commento obsoleto del 2020,
+    // issue #4606), ma su APFS il `backgroundImageAlias` nel .DS_Store NON
+    // risolve → sfondo finestra installazione bianco. Su HFS+ funziona. hdiutil
+    // su Apple Silicon moderno SUPPORTA HFS+ (testato). Override con
+    // FORCE_DMG_APFS=true se mai servisse APFS su un Mac che non supporta HFS+.
     let filesystem = ["HFS+", "-fsargs", "-c c=64,a=16,e=16"];
-    if (process.arch === "arm64") {
-        // Apple Silicon `hdiutil` dropped support for HFS+, so we force the latest type
-        // https://github.com/electron-userland/electron-builder/issues/4606
+    if (process.arch === "arm64" && process.env.FORCE_DMG_APFS === "true") {
         filesystem = ["APFS"];
-        builder_util_1.log.warn(null, "Detected arm64 process, HFS+ is unavailable. Creating dmg with APFS - supports Mac OSX 10.12+");
+        builder_util_1.log.warn(null, "FORCE_DMG_APFS=true: creating dmg with APFS (background image may not show)");
     }
     imageArgs.push("-fs", ...filesystem);
     imageArgs.push(tempDmg);

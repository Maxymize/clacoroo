{
  "name": "clacoroo",
  "version": "1.0.02",
  "description": "CLACOROO — Claude Code Control Room: pannello visuale per plugin, marketplace, skill e agent",
  "main": "src/main.js",
  "author": {
    "name": "Maximilian Giurastante",
    "email": "info@maxymizebusiness.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/Maxymize/clacoroo",
  "repository": {
    "type": "git",
    "url": "https://github.com/Maxymize/clacoroo.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.maxymize.clacoroo",
    "productName": "CLACOROO",
    "copyright": "Copyright © 2026 Maximilian Giurastante",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon": "assets/icon.icns",
      "darkModeSupport": true
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0"
  }
}

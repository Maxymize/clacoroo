{
  "name": "clacoroo",
  "version": "1.0.93",
  "description": "CLACOROO — Claude Code Control Room: pannello visuale per plugin, marketplace, skill e agent",
  "main": "src/main.js",
  "author": {
    "name": "Maximilian Giurastante",
    "email": "info@maxymizebusiness.com"
  },
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/Maxymize/clacoroo",
  "repository": {
    "type": "git",
    "url": "https://github.com/Maxymize/clacoroo.git"
  },
  "scripts": {
    "postinstall": "node scripts/fix-node-pty-perms.js",
    "start": "unset ELECTRON_RUN_AS_NODE; electron .",
    "build": "electron-builder --mac",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder -mwl"
  },
  "build": {
    "appId": "com.maxymize.clacoroo",
    "productName": "CLACOROO",
    "copyright": "Copyright © 2026 MAXYMIZE",
    "afterPack": "./build/after-pack.js",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/icon.png",
      "CHANGELOG.md",
      "package.json",
      "!**/*.{map,test.js}",
      "!**/{__tests__,test,tests,.github}"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "compression": "normal",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSHumanReadableCopyright": "Copyright © 2026 MAXYMIZE",
        "LSUIElement": false
      },
      "identity": null
    },
    "dmg": {
      "title": "${productName} ${version}",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "background": "build/dmg-background.png",
      "iconSize": 96,
      "iconTextSize": 13,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 220,
          "type": "file"
        },
        {
          "x": 400,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CLACOROO"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "assets/icon.png",
      "category": "Development",
      "synopsis": "Claude Code Control Room",
      "description": "Pannello visuale per gestire plugin, marketplace, skill e agent di Claude Code",
      "maintainer": "Maximilian Giurastante <info@maxymizebusiness.com>",
      "desktop": {
        "entry": {
          "Name": "CLACOROO",
          "Comment": "Claude Code Control Room",
          "Categories": "Development;Utility;",
          "StartupWMClass": "CLACOROO"
        }
      }
    }
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
